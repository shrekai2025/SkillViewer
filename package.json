{
  "name": "skillviewer",
  "private": true,
  "version": "0.2.0",
  "description": "Local-first macOS skill browser for managing agent skills across multiple folders.",
  "author": "Skillviewer contributors",
  "type": "module",
  "main": "dist-electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k -n renderer,electron,app -c \"cyan,magenta,green\" \"npm:dev:renderer\" \"npm:dev:electron\" \"npm:dev:app\"",
    "dev:app": "wait-on tcp:5173 file:dist-electron/main.cjs && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 nodemon --watch dist-electron --ext cjs --exec \"electron .\"",
    "dev:electron": "tsup --watch --config tsup.config.ts",
    "dev:renderer": "vite",
    "typecheck": "tsc -b",
    "build": "npm run typecheck && npm run build:renderer && npm run build:electron",
    "build:electron": "tsup --config tsup.config.ts",
    "build:renderer": "vite build",
    "dist:mac": "npm run build && electron-builder --mac",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/manrope": "^5.2.8",
    "extract-zip": "^2.0.1",
    "fast-glob": "^3.3.3",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.577.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.0.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "nodemon": "^3.1.14",
    "tsup": "^8.5.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "wait-on": "^9.0.4"
  }
}